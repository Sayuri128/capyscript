{
  "name": "capyscript",
  "displayName": "Capyscript",
  "description": "Syntax highlighting for the Capyscript scripting language",
  "version": "0.1.0",
  "publisher": "armatura24",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sayuri128/capyscript"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:capyscript"
  ],
  "categories": [
    "Programming Languages"
  ],
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "contributes": {
    "languages": [
      {
        "id": "capyscript",
        "aliases": ["Capyscript", "capyscript"],
        "extensions": [".capyscript"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "capyscript",
        "scopeName": "source.capyscript",
        "path": "./syntaxes/capyscript.tmLanguage.json"
      }
    ]
  }
}
