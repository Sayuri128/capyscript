{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Capyscript",
  "scopeName": "source.capyscript",
  "fileTypes": ["capyscript"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#class-declaration" },
    { "include": "#interface-declaration" },
    { "include": "#function-declaration" },
    { "include": "#new-expression" },
    { "include": "#this-super" },
    { "include": "#type-annotation" },
    { "include": "#keywords" },
    { "include": "#type-names" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#function-call" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.capyscript",
          "begin": "//",
          "end": "$"
        },
        {
          "name": "comment.block.capyscript",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.capyscript",
          "begin": "\"",
          "end": "\""
        },
        {
          "name": "string.quoted.single.capyscript",
          "begin": "'",
          "end": "'"
        },
        {
          "name": "string.quoted.other.capyscript",
          "begin": "`",
          "end": "`"
        }
      ]
    },
    "class-declaration": {
      "match": "\\b(class)\\s+([a-zA-Z_]\\w*)\\b",
      "captures": {
        "1": { "name": "keyword.declaration.class.capyscript" },
        "2": { "name": "entity.name.type.class.capyscript" }
      }
    },
    "interface-declaration": {
      "match": "\\b(interface)\\s+([a-zA-Z_]\\w*)\\b",
      "captures": {
        "1": { "name": "keyword.declaration.class.capyscript" },
        "2": { "name": "entity.name.type.interface.capyscript" }
      }
    },
    "function-declaration": {
      "match": "\\b(function)\\s+([a-zA-Z_]\\w*)\\b",
      "captures": {
        "1": { "name": "keyword.declaration.function.capyscript" },
        "2": { "name": "entity.name.function.capyscript" }
      }
    },
    "new-expression": {
      "match": "\\b(new)\\s+([a-zA-Z_]\\w*)\\b",
      "captures": {
        "1": { "name": "keyword.operator.new.capyscript" },
        "2": { "name": "entity.name.type.capyscript" }
      }
    },
    "this-super": {
      "name": "variable.language.capyscript",
      "match": "\\b(this|super)\\b"
    },
    "type-annotation": {
      "match": ":\\s*([a-zA-Z_]\\w*(?:<[^>]+>)?)",
      "captures": {
        "1": { "name": "storage.type.capyscript" }
      }
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.capyscript",
          "match": "\\b(if|else|for|return|break|continue|extends|implements)\\b"
        },
        {
          "name": "keyword.control.import.capyscript",
          "match": "\\b(import)\\b"
        },
        {
          "name": "keyword.declaration.capyscript",
          "match": "\\b(var)\\b"
        }
      ]
    },
    "type-names": {
      "name": "storage.type.capyscript",
      "match": "\\b(int|float|string|bool|void|any|dynamic|List|Map)\\b"
    },
    "constants": {
      "name": "constant.language.capyscript",
      "match": "\\b(true|false|null)\\b"
    },
    "numbers": {
      "name": "constant.numeric.capyscript",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    },
    "function-call": {
      "match": "\\b([a-zA-Z_]\\w*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.capyscript" }
      }
    },
    "operators": {
      "name": "keyword.operator.capyscript",
      "match": "(\\+\\+|--|==|!=|<=|>=|&&|\\|\\||[+\\-*/<>=])"
    }
  }
}
